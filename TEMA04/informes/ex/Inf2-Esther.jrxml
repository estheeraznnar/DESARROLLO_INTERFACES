	<parameter name="pro" class="java.lang.String"/>
	<query language="sql"><![CDATA[SELECT p.nombre, p.precio, t.tipo, pr.proveedor 
FROM productos p JOIN tipos t ON p.tipo=t.id 
JOIN proveedores pr ON p.proveedor=pr.id WHERE pr.proveedor=$P{pro}]]></query>
