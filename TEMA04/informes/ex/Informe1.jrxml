	<dataset name="DatasetTablaProveedor" uuid="cd16e938-7f5c-44aa-b9d0-1110dd0b7cb6">
		<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
		<property name="com.jaspersoft.studio.data.defaultdataadapter" value="AdaptadorExamen"/>
		<query language="SQL"><![CDATA[SELECT pr.proveedor, SUM(p.precio*p.unidades*1.21)
 AS Total_VentasConIva FROM productos p JOIN proveedores pr ON p.proveedor=pr.id GROUP BY pr.id]]></query>
		<field name="proveedor" class="java.lang.String">
			<property name="com.jaspersoft.studio.field.name" value="Proveedor"/>
			<property name="com.jaspersoft.studio.field.label" value="proveedor"/>
			<property name="com.jaspersoft.studio.field.tree.path" value="proveedores"/>
		</field>
		<field name="Total_VentasConIva" class="java.lang.Double">
			<property name="com.jaspersoft.studio.field.name" value="Total_VentasConIva"/>
			<property name="com.jaspersoft.studio.field.label" value="Total_VentasConIva"/>
		</field>
	</dataset>
	<dataset name="DatasetTipo" uuid="3057cc70-4b2c-408e-965d-905e8d4b9e6c">
		<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
		<property name="com.jaspersoft.studio.data.defaultdataadapter" value="AdaptadorExamen"/>
		<query language="SQL"><![CDATA[SELECT t.tipo, SUM(p.precio*p.unidades*1.21) AS Total_VentasConIva FROM productos p JOIN tipos t ON p.proveedor=t.id GROUP BY t.id;]]></query>
		<field name="tipo" class="java.lang.String">
			<property name="com.jaspersoft.studio.field.name" value="Tipo"/>
			<property name="com.jaspersoft.studio.field.label" value="tipo"/>
			<property name="com.jaspersoft.studio.field.tree.path" value="tipos"/>
		</field>
		<field name="Total_VentasConIva" class="java.lang.Double">
			<property name="com.jaspersoft.studio.field.name" value="Total_VentasConIva"/>
			<property name="com.jaspersoft.studio.field.label" value="Total_VentasConIva"/>
		</field>
	</dataset>
	<parameter name="tipo" class="java.lang.String"/>
	<parameter name="foto" class="java.io.InputStream"/>
	<query language="SQL"><![CDATA[SELECT p.nombre, p.unidades, t.tipo,
 pr.proveedor FROM productos p JOIN tipos t 
 ON p.tipo=t.id JOIN proveedores pr ON p.proveedor=pr.id WHERE t.tipo= $P{tipo}]]></query>
